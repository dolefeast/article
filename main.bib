	doi = {10.1103/PhysRevD.96.114501},
	abstract = {Matrix Product States (MPS) are used for the simulation of the real-time dynamics induced by an electric quench on the vacuum state of the massive Schwinger model. For small quenches it is found that the obtained oscillatory behavior of local observables can be explained from the single-particle excitations of the quenched Hamiltonian. For large quenches damped oscillations are found and comparison of the late time behavior with the appropriate Gibbs states seems to give some evidence for the onset of thermalization. Finally, the MPS real-time simulations are explicitly compared with the semi-classical approach and, as expected, agreement is found in the limit of large quenches.},
