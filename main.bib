	file = {PDF:/home/santi/Zotero/storage/LDEXQ2UU/Dempsey et al. - 2023 - Discrete Chiral Symmetry and Mass Shift in Lattice Hamiltonian Approach to Schwinger Model.pdf:application/pdf},
}

