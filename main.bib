	note = {arXiv:2203.00019 [hep-ph]},
	keywords = {High Energy Physics - Phenomenology, High Energy Physics - Theory, Physics - Plasma Physics},
	pages = {1--138},
	annote = {Comment: Review article: 175 pages, 38 figures. To appear in Physics Reports},
	file = {PDF:/home/santi/Zotero/storage/RWYQW9J2/Fedotov et al. - 2023 - Advances in QED with intense background fields.pdf:application/pdf},
