@article{juhasz_exact_2022,
	title = {Exact bounds on the energy gap of transverse-field {Ising} chains by mapping to random walks},
	volume = {106},
	issn = {2469-9950, 2469-9969},
	url = {http://arxiv.org/abs/2206.11575},
	doi = {10.1103/PhysRevB.106.064204},
	abstract = {Based on a relationship with continuous-time random walks discovered by Iglói, Turban, and Rieger [Phys. Rev. E \{{\textbackslash}bf 59\}, 1465 (1999)], we derive exact lower and upper bounds on the lowest energy gap of open transverse-field Ising chains, which are explicit in the parameters and are generally valid for arbitrary sets of possibly random couplings and fields. In the homogeneous chain and in the random chain with uncorrelated parameters, both the lower and upper bounds are found to show the same finite-size scaling in the ferromagnetic phase and at the critical point, demonstrating the ability of these bounds to infer the correct finite-size scaling of the critical gap. Applying the bounds to random transverse-field Ising chains with coupling-field correlations, a model which is relevant for adiabatic quantum computing, the finite-size scaling of the gap is shown to be related to that of sums of independent random variables. We determine the critical dynamical exponent of the model and reveal the existence of logarithmic corrections at special points.},
	number = {6},
	urldate = {2025-11-28},
	journal = {Physical Review B},
	author = {Juhász, Róbert},
	month = aug,
	year = {2022},
	note = {arXiv:2206.11575 [cond-mat]},
	keywords = {Condensed Matter - Disordered Systems and Neural Networks, Condensed Matter - Statistical Mechanics, Quantum Physics},
	pages = {064204},
	annote = {Comment: 10 pages},
	file = {Preprint PDF:/home/santi/Zotero/storage/BI9R9FYW/Juhász - 2022 - Exact bounds on the energy gap of transverse-field Ising chains by mapping to random walks.pdf:application/pdf;Snapshot:/home/santi/Zotero/storage/3R5YJCMB/2206.html:text/html},
