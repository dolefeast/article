@article{juhasz_hamiltonian_2025,
	title = {On {Hamiltonian} formulations of the {Dirac} system},
	volume = {472},
	issn = {0003-4916},
	url = {https://www.sciencedirect.com/science/article/pii/S0003491624002628},
	doi = {10.1016/j.aop.2024.169855},
	abstract = {We extend a previously successful discussion of the constrained Schrödinger system through the Dirac–Bergmann algorithm to the case of the Dirac field. In order to follow the analogy, first we discuss the classical Dirac field as a spinorial variable, by introducing properly defined momenta and a suitably modified, factor ordered Poisson bracket. According to the Dirac–Bergmann algorithm two second class Hamiltonian constraints emerge, leading to a factor ordered Dirac bracket on the full phase space. This becomes the Poisson bracket on the reduced phase space in the canonical chart adapted to the shell. The Dirac equation is recovered both as consistency condition on the full phase space and as canonical equation on the reduced phase space. Alternatively, considering the Dirac field as odd Grassmann variable, we present the details of the Dirac–Bergmann algorithm (with either left and right derivatives acting on Grassmann valued superfunctions and involving a different type of generalized Poisson and Dirac brackets). We propose a recipe for the canonical second quantization of all three versions of the generalized Dirac brackets, yielding the correct fundamental anticommutator.},
	urldate = {2026-01-26},
	journal = {Annals of Physics},
	author = {Juhász, Bence and Gergely, László Árpád},
	month = jan,
	year = {2025},
	keywords = {Canonical quantization, Constraints, Dirac field, Dirac–Bergmann algorithm, Generalized Dirac bracket},
	pages = {169855},
	file = {ScienceDirect Full Text PDF:/home/santi/Zotero/storage/2IL5VV44/Juhász and Gergely - 2025 - On Hamiltonian formulations of the Dirac system.pdf:application/pdf;ScienceDirect Snapshot:/home/santi/Zotero/storage/3NE5BIYC/S0003491624002628.html:text/html},
}

